<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:View_Class="clr-namespace:FitMyBike.View_Class"
    x:Class="FitMyBike.MainWindow"
        mc:Ignorable="d"
        Title="FitMyBike - Bikefitting at home" Height="810" Width="1600" PreviewKeyDown="Window_PreviewKeyDown" PreviewKeyUp="Window_PreviewKeyUp" Background="FloralWhite" WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="Button.Static.Background" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="Button.Static.Border" Color="#FF707070"/>
        <SolidColorBrush x:Key="Button.MouseOver.Background" Color="#FFBEE6FD"/>
        <SolidColorBrush x:Key="Button.MouseOver.Border" Color="#FF3C7FB1"/>
        <SolidColorBrush x:Key="Button.Pressed.Background" Color="#FFC4E5F6"/>
        <SolidColorBrush x:Key="Button.Pressed.Border" Color="#FF2C628B"/>
        <SolidColorBrush x:Key="Button.Disabled.Background" Color="#FFF4F4F4"/>
        <SolidColorBrush x:Key="Button.Disabled.Border" Color="#FFADB2B5"/>
        <SolidColorBrush x:Key="Button.Disabled.Foreground" Color="#FF838383"/>
        <Style x:Key="FitMyBike_ButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" Margin="1" Background="{TemplateBinding Background}" BorderBrush="DarkOrange" CornerRadius="10" BorderThickness="5" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDefaulted" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="Orange"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="DarkOrange"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="FloralWhite"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="DarkOrange"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="DarkOrange"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="FloralWhite"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Disabled.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Disabled.Border}"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource Button.Disabled.Foreground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="620"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="1280"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>
        <Border Background="LightGray" BorderBrush="DarkGray" Grid.Column="1" Grid.RowSpan="2" Grid.Row="1" BorderThickness="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" ClipToBounds="True">
            <Canvas x:Name="MainCanvas" HorizontalAlignment="Stretch"  Grid.Column="1" Grid.Row="1" MouseWheel="MainCanvas_MouseWheel" MouseLeftButtonDown="MainCanvas_MouseLeftButtonDown" MouseMove="MainCanvas_MouseMove" MouseLeftButtonUp="MainCanvas_MouseLeftButtonUp" Height="{Binding ActualHeight, ElementName=MainImageBox, Mode=OneWay}" MouseRightButtonDown="MainCanvas_MouseRightButtonDown">
                <Image x:Name="MainImageBox"   Stretch="UniformToFill" Width="{Binding ActualWidth, ElementName=MainCanvas, Mode=OneWay}" />
                <!--HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="1" Grid.Row="1"-->
            </Canvas>
        </Border>

        <Canvas x:Name="CycleValueGraphCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.Column="1" Grid.Row="2" IsHitTestVisible="False" ClipToBounds="True"/>
        <Slider x:Name="FrameSlider" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"  ValueChanged="FrameSlider_ValueChanged" />

        <Grid x:Name="InterfaceGrid" Grid.Column="3" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Label Foreground="DarkOrange" Grid.Column="0" Grid.Row="0" Content="FitMyBike™" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontWeight="DemiBold" FontSize="40" FontFamily="Impact"/>

            <Button Style="{DynamicResource FitMyBike_ButtonStyle}" Background="FloralWhite" Foreground="DarkOrange" x:Name="LoadImage" Grid.Column="0" Grid.Row="1" Content="Load Image" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="LoadImage_Click" FontWeight="Bold" FontSize="22" FontFamily="Verdana"/>
            <Button Style="{DynamicResource FitMyBike_ButtonStyle}" Background="FloralWhite" Foreground="DarkOrange" x:Name="LoadVideo" Grid.Column="0" Grid.Row="2" Content="Load Video" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="LoadVideo_Click" FontWeight="Bold" FontSize="22" FontFamily="Verdana"/>

            <Border Background="DarkOrange" BorderBrush="DarkOrange" CornerRadius="10" Grid.Column="0" Grid.Row="4" Grid.RowSpan="6" BorderThickness="4" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>

            <View_Class:ResultLabel x:Name="KneeAngleLabel"  Margin="10"  PoseAnglesReference="KneeAngle" Text="Knee angle" HorizontalAlignment="Stretch" Grid.Row="4" VerticalAlignment="Stretch"/>
            <View_Class:ResultLabel x:Name="BackAngleLabel"  Margin="10"  PoseAnglesReference="BackAngle" Text="Back angle" HorizontalAlignment="Stretch" Grid.Row="5" VerticalAlignment="Stretch"/>
            <View_Class:ResultLabel x:Name="ArmAngleLabel"  Margin="10"  PoseAnglesReference="ArmAngle" Text="Arm angle" HorizontalAlignment="Stretch" Grid.Row="6" VerticalAlignment="Stretch"/>
            <View_Class:ResultLabel x:Name="ElbowAngleLabel"  Margin="10"  PoseAnglesReference="ElbowAngle" Text="Elbow angle" HorizontalAlignment="Stretch" Grid.Row="7" VerticalAlignment="Stretch"/>
            <View_Class:ResultLabel x:Name="WholeArmAngleLabel"  Margin="10"  PoseAnglesReference="WholeArmAngle" Text="Whole arm angle" HorizontalAlignment="Stretch" Grid.Row="8" VerticalAlignment="Stretch"/>
            <View_Class:ResultLabel x:Name="FootAngleLabel"  Margin="10"  PoseAnglesReference="FootAngle" Text="Foot angle" HorizontalAlignment="Stretch" Grid.Row="9" VerticalAlignment="Stretch"/>

            <Button Style="{DynamicResource FitMyBike_ButtonStyle}" Background="FloralWhite" Foreground="DarkOrange" x:Name="Exit" Grid.Column="0" Grid.Row="11" Content="Exit" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="Exit_Click" FontWeight="DemiBold" FontSize="20" FontFamily="Verdana"/>
        </Grid>

    </Grid>
</Window>
